{"_id":"f9997f6e3ab3f45d","name":"Effect: Energizing Chew","type":"effect","img":"icons/svg/aura.svg","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":{"value":"<p>You gain a +1 status bonus to Acrobatics, Athletics, and Perception checks for 1 hour. If you were fatigued, the condition is suppressed for the duration.</p>"},"source":{"value":"Everything Archetypes: Wilderness"},"rules":[{"key":"FlatModifier","selector":"acrobatics","type":"status","value":1,"label":"Energizing Chew"},{"key":"FlatModifier","selector":"athletics","type":"status","value":1,"label":"Energizing Chew"},{"key":"FlatModifier","selector":"perception","type":"status","value":1,"label":"Energizing Chew"}],"slug":"effect-energizing-chew","schema":{"version":0.93,"lastMigration":{"datetime":"2026-04-08T15:18:47.755Z","version":{"schema":0.93,"foundry":"13","system":"6.0.0"}}},"level":{"value":8},"traits":{"value":[],"rarity":"common"},"duration":{"value":1,"unit":"hours","sustained":false,"expiry":"turn-start"},"start":{"value":0,"initiative":null},"tokenIcon":{"show":true}},"ownership":{"default":0},"_stats":{"systemId":"pf2e","systemVersion":"6.0.0","coreVersion":"13","createdTime":1775661527743,"modifiedTime":1775661527743,"lastModifiedBy":"generator"},"schemaVersion":13}
{"_id":"fae091f3ecb8de70","name":"Effect: Dietary Cleanse","type":"effect","img":"icons/svg/aura.svg","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":{"value":"<p>You gain a +2 circumstance bonus to Fortitude saves for 1 week.</p>"},"source":{"value":"Everything Archetypes: Wilderness"},"rules":[{"key":"FlatModifier","selector":"saving-throw:fortitude","type":"circumstance","value":2,"label":"Dietary Cleanse"}],"slug":"effect-dietary-cleanse","schema":{"version":0.93,"lastMigration":{"datetime":"2026-04-08T15:18:47.755Z","version":{"schema":0.93,"foundry":"13","system":"6.0.0"}}},"level":{"value":10},"traits":{"value":[],"rarity":"common"},"duration":{"value":-1,"unit":"unlimited","sustained":false,"expiry":"turn-start"},"start":{"value":0,"initiative":null},"tokenIcon":{"show":true}},"ownership":{"default":0},"_stats":{"systemId":"pf2e","systemVersion":"6.0.0","coreVersion":"13","createdTime":1775661527743,"modifiedTime":1775661527743,"lastModifiedBy":"generator"},"schemaVersion":13}
{"_id":"87a3025666e9ef20","name":"Effect: Evening Brew","type":"effect","img":"icons/svg/heal.svg","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":{"value":"<p>You gain temporary Hit Points equal to half the herbalist's level (or their full level if master in Nature). Lasts until next daily preparations.</p>"},"source":{"value":"Everything Archetypes: Wilderness"},"rules":[{"key":"TempHP","value":"floor(@actor.level/2)"}],"slug":"effect-evening-brew","schema":{"version":0.93,"lastMigration":{"datetime":"2026-04-08T15:18:47.755Z","version":{"schema":0.93,"foundry":"13","system":"6.0.0"}}},"level":{"value":6},"traits":{"value":[],"rarity":"common"},"duration":{"value":-1,"unit":"unlimited","sustained":false,"expiry":"turn-start"},"start":{"value":0,"initiative":null},"tokenIcon":{"show":true}},"ownership":{"default":0},"_stats":{"systemId":"pf2e","systemVersion":"6.0.0","coreVersion":"13","createdTime":1775661527743,"modifiedTime":1775661527743,"lastModifiedBy":"generator"},"schemaVersion":13}
{"_id":"63bf10a97fbf06c9","name":"Effect: Anesthetic Tincture","type":"effect","img":"icons/svg/aura.svg","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":{"value":"<p>The next time you are reduced to 0 HP but not killed, you instead remain at 1 HP, your wounded condition increases by 1, and you gain temporary HP equal to the herbalist's level for 1 minute. Then remove this effect.</p>"},"source":{"value":"Everything Archetypes: Wilderness"},"rules":[{"key":"Note","selector":"ac","text":"<p class=\"compact-text\"><strong>Anesthetic Tincture</strong> If reduced to 0 HP (not killed): stay at 1 HP, wounded +1, gain TempHP = herbalist level for 1 min. Then remove this effect.</p>"}],"slug":"effect-anesthetic-tincture","schema":{"version":0.93,"lastMigration":{"datetime":"2026-04-08T15:18:47.755Z","version":{"schema":0.93,"foundry":"13","system":"6.0.0"}}},"level":{"value":14},"traits":{"value":[],"rarity":"common"},"duration":{"value":-1,"unit":"unlimited","sustained":false,"expiry":"turn-start"},"start":{"value":0,"initiative":null},"tokenIcon":{"show":true}},"ownership":{"default":0},"_stats":{"systemId":"pf2e","systemVersion":"6.0.0","coreVersion":"13","createdTime":1775661527743,"modifiedTime":1775661527743,"lastModifiedBy":"generator"},"schemaVersion":13}
{"_id":"c473d62c45bf4d97","name":"Effect: Rejuvenate","type":"effect","img":"icons/svg/heal.svg","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":{"value":"<p>You gain fast healing 1 for 30 minutes.</p>"},"source":{"value":"Everything Archetypes: Wilderness"},"rules":[{"key":"FastHealing","value":1}],"slug":"effect-rejuvenate","schema":{"version":0.93,"lastMigration":{"datetime":"2026-04-08T15:18:47.755Z","version":{"schema":0.93,"foundry":"13","system":"6.0.0"}}},"level":{"value":8},"traits":{"value":[],"rarity":"common"},"duration":{"value":30,"unit":"minutes","sustained":false,"expiry":"turn-start"},"start":{"value":0,"initiative":null},"tokenIcon":{"show":true}},"ownership":{"default":0},"_stats":{"systemId":"pf2e","systemVersion":"6.0.0","coreVersion":"13","createdTime":1775661527743,"modifiedTime":1775661527743,"lastModifiedBy":"generator"},"schemaVersion":13}
{"_id":"3f5714e2cd233e13","name":"Effect: Tree of Life","type":"effect","img":"icons/svg/heal.svg","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":{"value":"<p>You gain regeneration 30 for 3 rounds (deactivated by fire damage).</p>"},"source":{"value":"Everything Archetypes: Wilderness"},"rules":[{"key":"FastHealing","value":30},{"key":"Note","selector":"ac","text":"<p class=\"compact-text\"><strong>Tree of Life</strong> This regeneration is deactivated by fire damage.</p>"}],"slug":"effect-tree-of-life","schema":{"version":0.93,"lastMigration":{"datetime":"2026-04-08T15:18:47.755Z","version":{"schema":0.93,"foundry":"13","system":"6.0.0"}}},"level":{"value":20},"traits":{"value":[],"rarity":"common"},"duration":{"value":3,"unit":"rounds","sustained":false,"expiry":"turn-start"},"start":{"value":0,"initiative":null},"tokenIcon":{"show":true}},"ownership":{"default":0},"_stats":{"systemId":"pf2e","systemVersion":"6.0.0","coreVersion":"13","createdTime":1775661527743,"modifiedTime":1775661527743,"lastModifiedBy":"generator"},"schemaVersion":13}
{"_id":"d7db6b01b4be17a6","name":"Effect: Terrain Guidance","type":"effect","img":"icons/svg/aura.svg","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":{"value":"<p>You gain a +2 circumstance bonus to skill checks to move through terrain and to saving throws against hazards. You ignore non-magical difficult terrain until the end of your turn.</p>"},"source":{"value":"Everything Archetypes: Wilderness"},"rules":[{"key":"FlatModifier","selector":"acrobatics","type":"circumstance","value":2,"label":"Terrain Guidance"},{"key":"FlatModifier","selector":"athletics","type":"circumstance","value":2,"label":"Terrain Guidance"}],"slug":"effect-terrain-guidance","schema":{"version":0.93,"lastMigration":{"datetime":"2026-04-08T15:18:47.755Z","version":{"schema":0.93,"foundry":"13","system":"6.0.0"}}},"level":{"value":4},"traits":{"value":[],"rarity":"common"},"duration":{"value":1,"unit":"rounds","sustained":false,"expiry":"turn-end"},"start":{"value":0,"initiative":null},"tokenIcon":{"show":true}},"ownership":{"default":0},"_stats":{"systemId":"pf2e","systemVersion":"6.0.0","coreVersion":"13","createdTime":1775661527743,"modifiedTime":1775661527743,"lastModifiedBy":"generator"},"schemaVersion":13}
{"_id":"bf23eb06eac863c4","name":"Effect: Detailed Report (+1)","type":"effect","img":"icons/svg/aura.svg","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":{"value":"<p>You gain a +1 circumstance bonus to Recall Knowledge checks about the creature described in the scout's report. (Scout has expert Perception.) Duration: 10 minutes.</p>"},"source":{"value":"Everything Archetypes: Wilderness"},"rules":[{"key":"FlatModifier","selector":["arcana","crafting","medicine","nature","occultism","religion","society"],"type":"circumstance","value":1,"label":"Detailed Report","predicate":["action:recall-knowledge"]}],"slug":"effect-detailed-report-1","schema":{"version":0.93,"lastMigration":{"datetime":"2026-04-08T15:18:47.755Z","version":{"schema":0.93,"foundry":"13","system":"6.0.0"}}},"level":{"value":6},"traits":{"value":[],"rarity":"common"},"duration":{"value":10,"unit":"minutes","sustained":false,"expiry":"turn-start"},"start":{"value":0,"initiative":null},"tokenIcon":{"show":true}},"ownership":{"default":0},"_stats":{"systemId":"pf2e","systemVersion":"6.0.0","coreVersion":"13","createdTime":1775661527743,"modifiedTime":1775661527743,"lastModifiedBy":"generator"},"schemaVersion":13}
