{"_id":"daf601221eee9fdd","name":"Effect: Marking Shot","type":"effect","img":"icons/svg/eye.svg","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":{"value":"<p>This creature has been marked. The next creature other than the attacker to Strike this target gains a +1 circumstance bonus to their attack roll. Remove after the next attack against this creature.</p>"},"source":{"value":"Everything Archetypes: Wilderness"},"rules":[],"slug":"effect-marking-shot","schema":{"version":0.93,"lastMigration":{"datetime":"2026-04-08T15:18:47.755Z","version":{"schema":0.93,"foundry":"13","system":"6.0.0"}}},"level":{"value":8},"traits":{"value":[],"rarity":"common"},"duration":{"value":1,"unit":"rounds","sustained":false,"expiry":"turn-end"},"start":{"value":0,"initiative":null},"tokenIcon":{"show":true}},"ownership":{"default":0},"_stats":{"systemId":"pf2e","systemVersion":"6.0.0","coreVersion":"13","createdTime":1775661527743,"modifiedTime":1775661527743,"lastModifiedBy":"generator"},"schemaVersion":13}
