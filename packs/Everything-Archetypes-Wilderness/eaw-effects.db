{"_id":"15e990cb1e0603e9","name":"Effect: Third Act (Enhanced Tale)","type":"effect","img":"icons/svg/downgrade.svg","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":{"value":"<p>This creature is off-guard for 1 round. The Spin Tale status bonus to attacks and damage against all villains increases to +2 for the remainder of the tale.</p>"},"source":{"value":"Everything Archetypes: Wilderness"},"rules":[],"slug":"effect-third-act-enhanced-tale","schema":{"version":0.93,"lastMigration":{"datetime":"2026-04-08T15:18:47.756Z","version":{"schema":0.93,"foundry":"13","system":"6.0.0"}}},"level":{"value":14},"traits":{"value":[],"rarity":"common"},"duration":{"value":1,"unit":"rounds","sustained":false,"expiry":"turn-start"},"start":{"value":0,"initiative":null},"tokenIcon":{"show":true}},"ownership":{"default":0},"_stats":{"systemId":"pf2e","systemVersion":"6.0.0","coreVersion":"13","createdTime":1775661527743,"modifiedTime":1775661527743,"lastModifiedBy":"generator"},"schemaVersion":13}
