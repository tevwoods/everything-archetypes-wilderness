{"_id":"6bd0f49f055bf010","name":"Effect: Hampering Critical","type":"effect","img":"icons/svg/downgrade.svg","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":{"value":"<p>You take a -10-foot circumstance penalty to all Speeds until the end of the attacker's next turn.</p>"},"source":{"value":"Everything Archetypes: Wilderness"},"rules":[{"key":"FlatModifier","selector":"speed","type":"circumstance","value":-10,"label":"Hampering Critical"}],"slug":"effect-hampering-critical","schema":{"version":0.93,"lastMigration":{"datetime":"2026-04-08T15:18:47.755Z","version":{"schema":0.93,"foundry":"13","system":"6.0.0"}}},"level":{"value":4},"traits":{"value":[],"rarity":"common"},"duration":{"value":1,"unit":"rounds","sustained":false,"expiry":"turn-end"},"start":{"value":0,"initiative":null},"tokenIcon":{"show":true}},"ownership":{"default":0},"_stats":{"systemId":"pf2e","systemVersion":"6.0.0","coreVersion":"13","createdTime":1775661527743,"modifiedTime":1775661527743,"lastModifiedBy":"generator"},"schemaVersion":13}
