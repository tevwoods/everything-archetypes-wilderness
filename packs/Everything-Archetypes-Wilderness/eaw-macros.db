{"_id":"a471976e480ad8e2","name":"Branch Out - Gather Information","type":"script","img":"systems/pf2e/icons/default-icons/feats.webp","command":"// Branch Out: Use Nature instead of Diplomacy to Gather Information\nconst actor = canvas.tokens.controlled[0]?.actor ?? game.user.character;\nif (!actor) return ui.notifications.warn(\"Select a token or assign a default character.\");\nconst skill = actor.skills?.nature;\nif (!skill) return ui.notifications.warn(\"This actor has no Nature skill.\");\nskill.roll({ extraRollOptions: [\"action:gather-information\"] });","scope":"global","folder":null,"sort":0,"flags":{},"ownership":{"default":0},"_stats":{"systemId":"pf2e","systemVersion":"6.0.0","coreVersion":"13","createdTime":1775661527743,"modifiedTime":1775661527743,"lastModifiedBy":"generator"}}
